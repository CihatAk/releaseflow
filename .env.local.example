# ==========================================
# ReleaseFlow Environment Configuration
# ==========================================

# GitHub OAuth App Credentials
# Create a GitHub OAuth App at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/login/callback (for development)
# For production, use your production URL
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ==========================================
# NextAuth.js Configuration
# ==========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# Supabase (Required for database storage)
# ==========================================
# Get your credentials at: https://supabase.com
# Project Settings > API > Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# ==========================================
# Error Tracking (Optional)
# ==========================================
# Get Sentry DSN at: https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ==========================================
# Analytics (Optional)
# ==========================================
# Umami Analytics - Self-hosted or cloud
# Get started at: https://umami.is
# NEXT_PUBLIC_UMAMI_URL=https://analytics.umami.is
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id

# ==========================================
# Site Configuration
# ==========================================
# Set your production URL
NEXT_PUBLIC_SITE_URL=https://releaseflow.dev

# ==========================================
# Lemon Squeezy (Optional - for payments)
# ==========================================
# Get your keys at: https://lemonsqueezy.com
# Dashboard > Settings > API
# LEMONSQUEEZY_API_KEY=your_lemon_api_key
# LEMONSQUEEZY_STORE_ID=your_store_id
# Get from Dashboard > Settings > Webhooks
# LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# Product variants from Dashboard > Products > Your Product > Variants
# LEMONSQUEEZY_PRO_VARIANT_ID=variant_xxx
# LEMONSQUEEZY_TEAM_VARIANT_ID=variant_xxx
