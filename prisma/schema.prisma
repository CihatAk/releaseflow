// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  github_id  Int         @unique
  username   String      @unique
  email      String?
  avatar_url String?
  created_at DateTime    @default(now())
  last_login DateTime    @updatedAt
  repos      Repo[]
  changelogs Changelog[] // User'ın changelog'ları
  aiKeys     UserAiKey[]
  settings   Settings?
  Analytics  Analytics[]

  @@index([github_id])
  @@index([username])
  @@index([created_at])
}

model Repo {
  id             String      @id @default(cuid())
  name           String
  full_name      String      @unique
  owner          String
  private        Boolean     @default(false)
  github_token   String?
  description    String?
  stars          Int         @default(0)
  forks          Int         @default(0)
  default_branch String      @default("main")
  collaborators  Json?        // Array of user IDs/info for collaboration
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  user_id        String
  user           User        @relation(fields: [user_id], references: [id])
  changelogs     Changelog[]
  Analytics      Analytics[]

  @@index([owner])
  @@index([user_id])
  @@index([full_name])
  @@index([created_at])
  @@index([updated_at])
}

model Changelog {
  id         String           @id @default(cuid())
  title      String?          // Optional title for the changelog
  version    String
  content    String           // Markdown content
  published  Boolean          @default(false)
  slug       String?          // URL-friendly slug: owner-repo-timestamp
  format     String           @default("markdown") // markdown, html, json, etc.
  stats      Json?            // Commit stats, contributors, etc.
  repo_id    String
  repo       Repo             @relation(fields: [repo_id], references: [id])
  user_id    String?
  user       User?            @relation(fields: [user_id], references: [id])
  events     ChangelogEvent[]
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  @@index([repo_id])
  @@index([user_id])
  @@index([version])
  @@index([published])
  @@index([slug])
  @@index([created_at])
  @@index([updated_at])
}

model ChangelogEvent {
  id          String     @id @default(cuid())
  event       String // 'view', 'export', 'generate', 'publish'
  changelogId String?
  changelog   Changelog? @relation(fields: [changelogId], references: [id])
  metadata    Json? // Extra data (format, stats, etc.)
  created_at  DateTime   @default(now())

  @@index([event])
  @@index([changelogId])
  @@index([created_at])
}

model Feedback {
  id         String   @id @default(cuid())
  name       String   @default("Anonymous")
  email      String?
  category   String   @default("feedback")
  message    String
  created_at DateTime @default(now())
}

model Settings {
  id            String   @id @default(cuid())
  user_id       String   @unique
  user          User     @relation(fields: [user_id], references: [id])
  githubToken   String?
  autoPublish   Boolean  @default(false)
  defaultFormat String   @default("markdown")
  webhookUrl    String?
  theme         String   @default("system") // system, light, dark
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([user_id])
}

model UserAiKey {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  provider   String // openai, groq, anthropic, mistral, etc.
  key        String // encrypted api key
  label      String?
  model      String? // default model for this provider
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([provider])
  @@index([is_active])
}

model Analytics {
  id         String   @id @default(cuid())
  event      String // 'page_view', 'changelog_generate', 'ai_call', etc.
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  repoId     String?
  repo       Repo?    @relation(fields: [repoId], references: [id])
  metadata   Json? // Extra data
  created_at DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([repoId])
  @@index([created_at])
}
