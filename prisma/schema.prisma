// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  github_id   Int      @unique
  username   String   @unique
  email      String?
  avatar_url String?
  created_at DateTime @default(now())
  last_login DateTime @updatedAt
  repos      Repo[]

  @@index([github_id])
  @@index([username])
  @@index([created_at])
}

model Repo {
  id            String       @id @default(cuid())
  name          String
  full_name     String       @unique
  owner        String
  private      Boolean      @default(false)
  github_token String?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  user_id      String
  user        User         @relation(fields: [user_id], references: [id])
  changelogs  Changelog[]

  @@index([owner])
  @@index([user_id])
  @@index([full_name])
  @@index([created_at])
  @@index([updated_at])
}

model Changelog {
  id          String   @id @default(cuid())
  version     String
  content    String
  published  Boolean  @default(false)
  slug        String?
  created_at DateTime @default(now())
  repo_id     String
  repo       Repo     @relation(fields: [repo_id], references: [id])

  @@index([repo_id])
  @@index([version])
  @@index([published])
  @@index([slug])
  @@index([created_at])
}

model Feedback {
  id         String   @id @default(cuid())
  name       String   @default("Anonymous")
  email      String?
  category  String   @default("feedback")
  message   String
  created_at DateTime @default(now())
}

model Settings {
  id             String   @id @default(cuid())
  githubToken    String?
  autoPublish   Boolean  @default(false)
  defaultFormat String   @default("markdown")
  webhookUrl   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model UserAiKey {
  id         String   @id @default(cuid())
  user_id    String
  provider   String   // openai, groq, anthropic, google, mistral, etc.
  key        String   // encrypted api key
  label      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([provider])
  @@index([is_active])
}